# --- Local webhook server ---
PORT=3000
WEBHOOK_PATH=/api/webhook

# --- GitHub App (Session 2 setup) ---
# Set this to the "Webhook secret" you enter when creating the GitHub App.
GITHUB_WEBHOOK_SECRET=

# --- Storage ---
# SQLite file, relative to the agent/ directory.
DATABASE_PATH=revue.db

